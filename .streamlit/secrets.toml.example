# Plantilla de secrets para el explorador de cambio climático.
#
# Local: copiar a `.streamlit/secrets.toml` (mismo nivel) y rellenar.
# Streamlit Cloud: pegar este contenido en
#   App settings → Secrets (sin la línea [github] inicial puede omitirse).
#
# Si NO se configura el bloque [github], la app cae a JSON local
# (`seleccion_revision.json` en esta carpeta) — útil en desarrollo.

[github]
# Personal Access Token con permiso `Contents: read & write` sobre el repo destino.
# Crear en: https://github.com/settings/tokens?type=beta
token = "ghp_xxx_reemplazar"

# Repo donde se versiona el JSON. Formato "owner/nombre".
repo = "CepalLab/cambio-climatico"

# Ruta dentro del repo. El default en seleccion.py es
# "experimentos/cambio_climatico/seleccion_revision.json", pero como ahora la
# app vive en la raíz del repo, sobrescribimos a "seleccion_revision.json".
path = "seleccion_revision.json"

# Rama destino. Por defecto: main
branch = "main"
